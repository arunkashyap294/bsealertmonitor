# Corporate Announcement Monitor — Environment Variables
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control

# ---- Google Gemini API ----
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ---- Telegram Bot API (Free) ----
# 1. Create a bot via @BotFather on Telegram to get BOT_TOKEN
# 2. Send /start to your new bot in Telegram (Required!)
# 3. Run: python get_telegram_chat_id.py (to get your CHAT_ID)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here